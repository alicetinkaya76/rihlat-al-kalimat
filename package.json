{
  "name": "rihla",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Riḥlat al-Kalimāt — etimolojik bilgi grafı. Vite + React + i18next iskelesi.",
  "scripts": {
    "manifest": "tsx scripts/generate-manifest.mjs",
    "validate": "tsx scripts/validate-corpus.mjs",
    "sitemap": "tsx scripts/generate-sitemap.mjs",
    "predev": "tsx scripts/generate-manifest.mjs",
    "dev": "vite",
    "pretypecheck": "tsx scripts/generate-manifest.mjs",
    "typecheck": "tsc -b",
    "prebuild": "tsx scripts/generate-manifest.mjs && tsx scripts/validate-corpus.mjs && tsx scripts/generate-sitemap.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "d3": "^7.9.0",
    "framer-motion": "^11.11.17",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.2",
    "js-yaml": "^4.1.0",
    "leaflet": "^1.9.4",
    "marked": "^15.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/d3": "^7.4.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.18",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
